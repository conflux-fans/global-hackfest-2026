# Backend (local dev; docker/nginx often uses VITE_API_URL=/api and same-origin WS)
VITE_API_URL=http://localhost:3001/api
# Leave empty on Vercel (no native websocket server in serverless runtime).
VITE_WS_URL=
# Local/backend deployment only:
# VITE_WS_URL=ws://localhost:3002

# Optional: WalletConnect / app metadata base URL (defaults to window.location.origin in dev)
# VITE_APP_URL=http://localhost:5173

# Network (Conflux eSpace Testnet) — primary RPC; wagmi adds https://evmtestnet.confluxrpc.org as fallback
VITE_CHAIN_ID=71
VITE_RPC_URL=https://evmtestnet.confluxrpc.com
VITE_CONFLUX_TESTNET_RPC_URL=https://evmtestnet.confluxrpc.com
# https://cloud.walletconnect.com
VITE_WALLET_CONNECT_PROJECT_ID=3a8170812b534d0ff9d794f19a901d64

# Contract addresses — sync with deployment/confluxTestnet.json (2026-04-14)
VITE_TRADING_CORE_ADDRESS=0x64f277f73bfc81Ad80286a4266c0E0613d867Df3
VITE_VAULT_CORE_ADDRESS=0xB5C983d038caA21f4a9520b0EFAb2aD71DE4e714
VITE_ORACLE_AGGREGATOR_ADDRESS=0x89cC8eAbF2e967d81FD04D1023298A3bDcE67450
VITE_POSITION_TOKEN_ADDRESS=0x4368b5741A105c1ACE50ad98581fDa050685fa8B
VITE_MOCK_USDC_ADDRESS=0xa56Ba38f3c820D6cf31a68CBBD0d25c0F5644d35

# Development
VITE_MOCK_MODE=false
