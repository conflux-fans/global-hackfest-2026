# ============================================
# REQUIRED — Deployment Account
# ============================================

# Private key for deployment (without 0x prefix)
PRIVATE_KEY=

# Alternative: Use mnemonic phrase instead of private key
# MNEMONIC=

# ============================================
# RPC URLs — Network Endpoints
# ============================================

# Conflux eSpace
CONFLUX_RPC_URL=https://evm.confluxrpc.com
# Must match hardhat.config.ts default (see CONFLUX_TESTNET_RPC_URL there)
CONFLUX_TESTNET_RPC_URL=https://evmtestnet.confluxrpc.com
# Deploy/network RPC request timeout in milliseconds (default in config: 900000)
# DEPLOY_RPC_TIMEOUT_MS=900000
CONFLUXSCAN_API_KEY=

# ============================================
# Contract Deployment — Addresses
# ============================================

# Treasury address for protocol fees (required for mainnet)
TREASURY_ADDRESS=

# USDC token address (optional — uses network defaults; set to skip MockUSDC on testnet)
# USDC_ADDRESS=

# Pyth contract address (optional — each network has a default; override here if needed)
# PYTH_ADDRESS=

# ============================================
# Post-Deployment Addresses
# Used by: verify.ts, setup-market.ts, update-market.ts,
#          unlist-market.ts, grant-operator.ts
# ============================================
# If these are empty, verify.ts will auto-read from deployment/<network>.json.
# Override after your own deploy, or leave empty to use the deployment JSON.

# deployment/confluxTestnet.json (2026-04-14)
DEPLOYED_ORACLE_AGGREGATOR=0x89cC8eAbF2e967d81FD04D1023298A3bDcE67450
DEPLOYED_VAULT_CORE=0xB5C983d038caA21f4a9520b0EFAb2aD71DE4e714
DEPLOYED_POSITION_TOKEN=0x4368b5741A105c1ACE50ad98581fDa050685fa8B
DEPLOYED_TRADING_CORE=0x64f277f73bfc81Ad80286a4266c0E0613d867Df3
DEPLOYED_MARKET_CALENDAR=0xD3c20cca25Dd8189ed6115A1b65192d831ca732F
DEPLOYED_DIVIDEND_MANAGER=0xa5bd07176Ef68D1ec51BfCCD911d3B586a45c54F
DEPLOYED_COMPLIANCE_MANAGER=0xa79185D94013FaC946Ce80fDbB8E781200A28F7e
DEPLOYED_DIVIDEND_KEEPER=0x28B46F65c26BDC6b9c77603B092EDdcd7EADEC82
DEPLOYED_TRADING_CORE_VIEWS=0x944d4030CEc4Bf552d8E46dC684B70B100Eb0b86
DEPLOYED_MOCK_USDC=0xa56Ba38f3c820D6cf31a68CBBD0d25c0F5644d35
# When deploy uses MockPyth (no PYTH_ADDRESS on network):
# DEPLOYED_MOCK_PYTH=0x...

# ============================================
# Upgrade Script (upgrade.ts)
# ============================================
# npm run upgrade:conflux-testnet

# TradingCore only: bytecode links these libraries (deploy fresh libs, then set env):
# LIB_TRADING_LIB=0x...
# LIB_CLEANUP_LIB=0x...
# LIB_CONFIG_LIB=0x...
# LIB_DUST_LIB=0x...
# LIB_FLASH_LOAN_CHECK=0x...
# LIB_FUNDING_LIB=0x...
# LIB_HEALTH_LIB=0x...
# LIB_POSITION_TRIGGERS_LIB=0x...
# LIB_RATE_LIMIT_LIB=0x...
# LIB_TRADING_CONTEXT_LIB=0x...
# LIB_WITHDRAW_LIB=0x...
# OracleAggregator / TradingCoreViews use internal libs only — no LIB_* vars for those upgrades.

# ============================================
# Market Setup (setup-market.ts)
# ============================================
# Single market:
#   MARKET_ADDRESS=0x...
#   PYTH_FEED_ID=0x...
#   MARKET_ID=optional
#
# Multiple markets (comma-separated; same count for addresses and feed IDs):
#   MARKET_ADDRESSES=0x...,0x...
#   PYTH_FEED_IDS=0x...,0x...
#   MARKET_IDS=id1,id2   (optional, one per market)
#
# Shared for all markets:
# MARKET_ADDRESS=0x...
# PYTH_FEED_ID=0x...
# MARKET_ADDRESSES=0x986a...,0x886a...
# PYTH_FEED_IDS=0xe62df6...,0xff6149...
# MARKET_ID=
# MARKET_IDS=
# MAX_LEVERAGE=50
# MAX_POSITION_SIZE=100000000000000000000000
# MAX_EXPOSURE=50000000000000000000000000
# MAINTENANCE_MARGIN_BPS=500
# INITIAL_MARGIN_BPS=1000
# MAX_STALENESS=900

# Update existing market (update-market.ts):
# MARKET_ADDRESS=0x...  PYTH_FEED_ID=0x...  MARKET_ID=...  MAX_LEVERAGE=20  etc.

# Unlist market (unlist-market.ts) — frees a slot:
# MARKET_ADDRESS=0x...   or   UNLIST_MARKET_ADDRESS=0x...

# Generate a deterministic market address:
#   npm run market:address -- TSLA

# ============================================
# Grant OPERATOR_ROLE (grant-operator.ts)
# ============================================
# GRANT_TO_ADDRESS=0x...  (defaults to deployer signer)
# Used by grant-keeper-role.ts as well.

# ============================================
# Auto Keeper Bot (scripts/keeper-bot.ts)
# ============================================
# Optional override; defaults to HARDHAT_NETWORK or "confluxTestnet"
# KEEPER_NETWORK=confluxTestnet
# Defaults to CONFLUX_TESTNET_RPC_URL/CONFLUX_RPC_URL if not set
# KEEPER_RPC_URL=https://evmtestnet.confluxrpc.com
# Optional CSV fallback endpoints (bot rotates on timeout)
# KEEPER_RPC_URLS=https://evmtestnet.confluxrpc.com,https://evmtestnet.confluxrpc.org
# Retry attempts per RPC call before giving up
# KEEPER_RPC_MAX_ATTEMPTS=3
# Hermes endpoint base URL for Pyth updates
# KEEPER_HERMES_URL=https://hermes.pyth.network
# Private key for keeper wallet (falls back to PRIVATE_KEY)
# KEEPER_PRIVATE_KEY=
# Defaults to DEPLOYED_TRADING_CORE or deployment/<network>.json
# KEEPER_TRADING_CORE_ADDRESS=0x...
# Poll loop interval (seconds)
# KEEPER_POLL_INTERVAL_SECONDS=3
# How many historical blocks to backfill at startup
# KEEPER_LOOKBACK_BLOCKS=20000
# Chunk size for getLogs scanning
# KEEPER_BLOCK_CHUNK_SIZE=4000
# Minimum interval between price refreshes for same market
# KEEPER_MIN_PRICE_REFRESH_SECONDS=20

# ============================================
# Frontend Build Args (docker-compose / Vercel) — see also frontend/.env.example
# ============================================
# VITE_RPC_URL=https://evmtestnet.confluxrpc.com
# VITE_CONFLUX_TESTNET_RPC_URL=https://evmtestnet.confluxrpc.com
# VITE_APP_URL=https://your-app.example   (optional; WalletConnect / metadata)
# VITE_API_URL=/api
# VITE_WS_URL=                # Vercel-only deployment (polling mode)
# VITE_WS_URL=ws://localhost:3000/ws  # local/docker websocket
# VITE_WALLET_CONNECT_PROJECT_ID=
# VITE_POSITION_TOKEN_ADDRESS=0x4368b5741A105c1ACE50ad98581fDa050685fa8B
# VITE_ORACLE_AGGREGATOR_ADDRESS=0x89cC8eAbF2e967d81FD04D1023298A3bDcE67450
# VITE_VAULT_CORE_ADDRESS=0xB5C983d038caA21f4a9520b0EFAb2aD71DE4e714
# VITE_TRADING_CORE_ADDRESS=0x64f277f73bfc81Ad80286a4266c0E0613d867Df3
# VITE_MOCK_USDC_ADDRESS=0xa56Ba38f3c820D6cf31a68CBBD0d25c0F5644d35

# ============================================
# NPM scripts (run from repository root; see package.json)
# ============================================
# ABIs:  npm run contracts:sync   — hardhat compile + export ABIs to backend/src/abi & frontend/src/abi
#        npm run export-abi      — export only (expects artifacts present)
#        npm run sync:frontend-abi — copy TradingCore/VaultCore/OracleAggregator JSON to frontend
# Build: npm run compile | compile:force
# Apps:  npm run backend:dev | frontend:dev | backend:typecheck | frontend:typecheck
# Infra: npm run infra:up | infra:up:full | infra:down  (Windows: scripts/docker-up.ps1)

# ============================================
# Development & Testing
# ============================================

# Enable gas reporting
REPORT_GAS=false

# CoinMarketCap API for USD gas estimates
COINMARKETCAP_API_KEY=

# Skip confirmation prompts for mainnet deployment
# SKIP_CONFIRMATIONS=false

# Override gas price (gwei) for deploy/scripts if "replacement transaction underpriced"
# Example: GAS_PRICE_GWEI=25
# GAS_PRICE_GWEI=
